# ============================================================
# GoHotel ERP Backend — Environment Configuration
# ============================================================
# Copy this file to .env and update values for your environment.

# --- Application ---
APP_NAME=GoHotel
APP_VERSION=1.0.0
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string-at-least-64-chars

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://postgres:toor@13.140.185.49:5432/hotels-db
DATABASE_URL_SYNC=postgresql://postgres:toor@13.140.185.49:5432/hotels-db
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600

# --- JWT ---
JWT_SECRET_KEY=change-me-jwt-secret-at-least-64-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- MinIO / S3-Compatible Storage ---
MINIO_ENDPOINT=13.140.185.49:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=h0vgr3kybytaayey
MINIO_SECURE=false
MINIO_BUCKET_DOCUMENTS=hotel-documents
MINIO_BUCKET_GUESTS=hotel-guests

# --- Rate Limiting ---
RATE_LIMIT_LOGIN_PER_IP=5
RATE_LIMIT_LOGIN_PER_USER=10
RATE_LIMIT_WINDOW_SECONDS=60

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# --- Logging ---
LOG_LEVEL=DEBUG
LOG_FORMAT=json
